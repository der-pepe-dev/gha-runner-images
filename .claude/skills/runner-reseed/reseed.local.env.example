# Copy to reseed.local.env (gitignored) and fill for your fleet.
# SSH key that reaches the orchestrator LXCs as root (to pause/resume timer+socket).
ORCH_SSH_KEY="$HOME/.ssh/orch_key"

# Orchestrator LXCs are DHCP, so map each node to its orchestrator LXC *VMID* (stable);
# the skill resolves the current IP from the Proxmox API at run time.
ORCH_VMID_pve1="290"
ORCH_VMID_pve2="291"
ORCH_VMID_pve3="292"

# Alternatively pin a static IP per node (overrides VMID lookup): ORCH_IP_pve1="192.168.0.163"
# Optional clone storage (default OsdPool): RESEED_STORAGE="OsdPool"

# Example config for gha-orch01 on pve01.
# Copy to node.local.env and replace placeholders. Do not commit real values.
#
# This is a flat, shell-sourceable config (no YAML parser needed). Secrets are NOT
# here — PROXMOX_TOKEN_ID, PROXMOX_TOKEN, and GITHUB_TOKEN come from the environment
# (systemd unit / EnvironmentFile), never from this file.

PROXMOX_URL="https://pve.example.local:8006/api2/json"
PROXMOX_NODE="pve01"
GITHUB_OWNER="CHANGE_ME_ORG_OR_USER"
GITHUB_REPO="CHANGE_ME_REPO_OR_ORG_SCOPE"
REGISTRATION_SCOPE="repo"        # repo or org
MODE="snapshot-rollback"         # snapshot-rollback or destroy-reclone

# Windows template eval-age check (check-windows-template-age.sh). Optional.
# Windows Server eval clock starts at template build; warn before it expires.
WIN_TEMPLATE_EVAL_MAX_DAYS="100"     # alert at/over this age
WIN_TEMPLATE_EVAL_PERIOD_DAYS="180"  # Server 2022 eval window

# Runner slots. Use SLOT_COUNT and indexed SLOT_<n>_* vars.
SLOT_COUNT=2

SLOT_1_NAME="gha-linux01"
SLOT_1_VMID="301"
SLOT_1_TEMPLATE_VMID="9002"
SLOT_1_CLEAN_SNAPSHOT="clean"
SLOT_1_OS="linux"
SLOT_1_LABELS="self-hosted,linux,x64,dotnet10,proxmox,pve01,ephemeral"

SLOT_2_NAME="gha-win01"
SLOT_2_VMID="311"
SLOT_2_TEMPLATE_VMID="9001"
SLOT_2_CLEAN_SNAPSHOT="clean"
SLOT_2_OS="windows"
SLOT_2_LABELS="self-hosted,windows,x64,dotnet10,proxmox,pve01,ephemeral"

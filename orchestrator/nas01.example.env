# Example config for a NAS/high-capacity local orchestrator.
# Copy to node.local.env and replace placeholders. Do not commit real values.
# Secrets come from the environment (PROXMOX_TOKEN_ID, PROXMOX_TOKEN, GITHUB_TOKEN).

PROXMOX_URL="https://nas-proxmox.example.local:8006/api2/json"
PROXMOX_NODE="nas01"
GITHUB_OWNER="CHANGE_ME_ORG_OR_USER"
GITHUB_REPO="CHANGE_ME_REPO_OR_ORG_SCOPE"
REGISTRATION_SCOPE="org"         # repo or org
MODE="snapshot-rollback"         # snapshot-rollback, destroy-reclone, or platform-specific reset

SLOT_COUNT=2

SLOT_1_NAME="gha-nas-linux01"
SLOT_1_VMID="401"
SLOT_1_TEMPLATE_VMID="9401"
SLOT_1_CLEAN_SNAPSHOT="clean"
SLOT_1_OS="linux"
SLOT_1_LABELS="self-hosted,linux,x64,dotnet10,nas,beefy,ephemeral"

# Optional. Set SLOT_COUNT=1 to disable the Windows NAS runner.
SLOT_2_NAME="gha-nas-win01"
SLOT_2_VMID="411"
SLOT_2_TEMPLATE_VMID="9402"
SLOT_2_CLEAN_SNAPSHOT="clean"
SLOT_2_OS="windows"
SLOT_2_LABELS="self-hosted,windows,x64,dotnet10,nas,beefy,vs-buildtools,ephemeral"
